{
  "name": "nbs-card-scoring-frontend",
  "root": ".",
  "sourceRoot": "src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/angular:webpack-browser",
      "outputs": ["{options.outputPath}"],
      "options": {
        "index": "src/index.html",
        "main": "src/main.ts",
        "polyfills": "src/polyfills.ts",
        "tsConfig": "tsconfig.app.json",
        "assets": ["src/favicon.ico", "src/assets"],
        "styles": [
          "src/styles.css"
        ],
        "scripts": []
      },
      "configurations": {
        "production": {
          "outputPath": "dist/production",
          "optimization": true,
          "outputHashing": "all",
          "sourceMap": false,
          "namedChunks": false,
          "aot": true,
          "extractLicenses": true,
          "vendorChunk": false,
          "fileReplacements": [
            {
              "replace": "src/environments/environment.ts",
              "with": "src/environments/environment.prod.ts"
            }
          ]
        },
        "staging": {
          "outputPath": "dist/staging",
          "optimization": true,
          "outputHashing": "all",
          "sourceMap": true,
          "namedChunks": true,
          "aot": true,
          "extractLicenses": true,
          "vendorChunk": true,
          "fileReplacements": [
            {
              "replace": "src/environments/environment.ts",
              "with": "src/environments/environment.staging.ts"
            }
          ]
        },
        "development": {
          "outputPath": "dist/development",
          "optimization": false,
          "outputHashing": "none",
          "sourceMap": true,
          "namedChunks": true,
          "aot": false,
          "buildOptimizer": false,
          "extractLicenses": false,
          "vendorChunk": true,
          "fileReplacements": [
            {
              "replace": "src/environments/environment.ts",
              "with": "src/environments/environment.staging.ts"
            }
          ]
        }
      }
    },
    "serve": {
      "executor": "@nx/angular:dev-server",
      "options": {
        "buildTarget": "nbs-card-scoring-frontend:build",
        "port": 1928,
        "publicHost": "http://localhost:1928",
        "disableHostCheck": true
      },
      "configurations": {
        "production": {
          "buildTarget": "nbs-card-scoring-frontend:build:production"
        },
        "staging": { "buildTarget": "nbs-card-scoring-frontend:build:staging" },
        "development": {
          "buildTarget": "nbs-card-scoring-frontend:build:development",
          "poll": 3000
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["src/**/*.ts", "src/**/*.html"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage"],
      "options": {
        "jestConfig": "jest.config.js",
        "passWithNoTests": true
      }
    }
  }
}
