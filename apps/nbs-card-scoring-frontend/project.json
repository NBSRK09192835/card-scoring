{
  "name": "nbs-card-scoring-frontend",
  "root": "apps/nbs-card-scoring-frontend",
  "sourceRoot": "apps/nbs-card-scoring-frontend/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/angular:webpack-browser",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/nbs-card-scoring-frontend",
        "index": "apps/nbs-card-scoring-frontend/src/index.html",
        "main": "apps/nbs-card-scoring-frontend/src/main.ts",
        "polyfills": "apps/nbs-card-scoring-frontend/src/polyfills.ts",
        "tsConfig": "apps/nbs-card-scoring-frontend/tsconfig.app.json",
        "assets": ["apps/nbs-card-scoring-frontend/src/favicon.ico", "apps/nbs-card-scoring-frontend/src/assets"],
        "styles": ["apps/nbs-card-scoring-frontend/src/styles.css"],
        "scripts": []
      },
      "configurations": {
        "production": {
          "optimization": true,
          "outputHashing": "all",
          "sourceMap": false,
          "namedChunks": false,
          "aot": true,
          "extractLicenses": true,
          "vendorChunk": false,
          "fileReplacements": [
            { "replace": "apps/nbs-card-scoring-frontend/src/environments/environment.ts", "with": "apps/nbs-card-scoring-frontend/src/environments/environment.prod.ts" }
          ]
        },
        "staging": {
          "optimization": true,
          "outputHashing": "all",
          "sourceMap": true,
          "namedChunks": true,
          "aot": true,
          "extractLicenses": true,
          "vendorChunk": true,
          "fileReplacements": [
            { "replace": "apps/nbs-card-scoring-frontend/src/environments/environment.ts", "with": "apps/nbs-card-scoring-frontend/src/environments/environment.staging.ts" }
          ]
        }
      }
    },
    "serve": {
      "executor": "@nx/angular:dev-server",
      "options": {
        "buildTarget": "nbs-card-scoring-frontend:build",
        "host": "0.0.0.0",
        "port": 1928,
        "publicHost": "http://localhost:1928",
        "disableHostCheck": true
      },
      "configurations": {
        "production": { "buildTarget": "nbs-card-scoring-frontend:build:production" },
        "staging": { "buildTarget": "nbs-card-scoring-frontend:build:staging" }
      }
    },
    "lint": {
      "executor": "@nx/linter:eslint",
      "options": {
        "lintFilePatterns": ["apps/nbs-card-scoring-frontend/src/**/*.ts", "apps/nbs-card-scoring-frontend/src/**/*.html"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/apps/nbs-card-scoring-frontend"],
      "options": {
        "jestConfig": "apps/nbs-card-scoring-frontend/jest.config.js",
        "passWithNoTests": true
      }
    }
  }
}
